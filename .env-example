DB_NAME="photo_classification_db"
DB_USER="postgres"
DB_PASSWORD="postgres"
DB_HOST="localhost"
DB_PORT=1234

# Run `openssl rand -hex 32` to generate a random 32-byte (256-bit) hex string for the secret
SECRET_KEY="secret-key-here"
SECRET_KEY_ALGORITHM="HS256"

# Garage S3 storage configuration
# To set up some of these values, the following Docker commands need to be run once:
# # Get the garage node ID
# docker compose exec garage /garage node id

# # Create the cluster layout (replace <node-id> with the output above)
# docker compose exec garage /garage layout assign -z dc1 -c 1G <node-id>
# docker compose exec garage /garage layout apply --version 1

# # Create an access key and bucket
# docker compose exec garage /garage key create my-app-key
# docker compose exec garage /garage bucket create profile-pictures
# docker compose exec garage /garage bucket allow --read --write profile-pictures --key my-app-key

STORAGE_ENDPOINT="http://localhost:9000"
STORAGE_ACCESS_KEY="access-key-here"
STORAGE_SECRET_KEY="secret-key-here"
STORAGE_BUCKET_PROFILE_PICTURES="profile-pictures"
# Run `openssl rand -hex 32` to generate a random 32-byte hex string for the secret
GARAGE_RPC_SECRET="rpc-secret-here"